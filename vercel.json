{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-subscription-expiry",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/cutoff-reminder-lunch",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/kitchen-list-lunch",
      "schedule": "31 3 * * *"
    },
    {
      "path": "/api/cron/resume-subscriptions",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/cutoff-reminder-dinner",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/kitchen-list-dinner",
      "schedule": "31 10 * * *"
    },
    {
      "path": "/api/cron/generate-daily-orders",
      "schedule": "30 18 * * *"
    }
  ]
}
